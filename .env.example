# Perpl Mainnet Market Maker Configuration
# Copy to .env and fill in your values

# Private key for the trading wallet (must be whitelisted on Perpl for API if used, and MUST have on-chain exchange account)
PRIVATE_KEY=0xYourPrivateKeyHere

# Mainnet RPC (public or your own)
RPC_URL=https://rpc.monad.xyz

# Perpl Mainnet Exchange (from https://github.com/PerplFoundation/api-docs)
EXCHANGE_ADDRESS=0x34B6552d57a35a1D042CcAe1951BD1C370112a6F
COLLATERAL_TOKEN=0x00000000eFE302BEAA2b3e6e1b18d08D69a9012a

# Default market to MM (use numeric ID for mainnet)
# 1=BTC, 10=MON, 20=ETH, 30=SOL
PERP_ID=1

# MM params (override via CLI flags too)
ORDER_SIZE_USD=10
SPREAD_BPS=1
LEVERAGE=2
MAX_POS_USD=10
INTERVAL_SEC=10

# Mode: set to "false" to enable live trading (default is dry-run safe)
# LIVE=true

# Optional: use Perpl public WS/REST for faster market data (no auth for market data)
# PERPL_API_URL=https://app.perpl.xyz/api
# PERPL_WS_URL=wss://app.perpl.xyz
